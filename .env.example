# Optional HTTP Basic Auth for the web UI.
# Keep real passwords in your private .env, shell, systemd drop-in, or
# Docker Compose override. Do not commit real credentials.
BUDGETPILOT_USER=saldo
BUDGETPILOT_PASSWORD=

# Optional runtime home. BudgetPilot stores JSON data in $BUDGETPILOT_HOME/data.
# Leave unset for the historical default: ~/BudgetPilot/data.
# BUDGETPILOT_HOME=/path/to/private/budgetpilot-home

# Native run listen address and port. Docker Compose uses BUDGETPILOT_BIND for
# the host-side bind address and keeps the container listening internally.
BUDGETPILOT_HOST=127.0.0.1
BUDGETPILOT_PORT=8765
BUDGETPILOT_BIND=127.0.0.1
BUDGETPILOT_HOST_PORT=8765
BUDGETPILOT_WORKERS=2

# Set to true only behind a trusted HTTPS reverse proxy.
BUDGETPILOT_COOKIE_SECURE=false
BUDGETPILOT_PROXY_FIX=false
# BUDGETPILOT_PUBLIC_URL=https://budgetpilot.example.invalid
